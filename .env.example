# Facebook App
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here
CONTACT_EMAIL=support@yourdomain.com

# --- Email (pick ONE) ---
# RECOMMENDED: Resend — https://resend.com → API Keys → add/verify your domain → use noreply@yourdomain.com
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key_here
# Test (no domain): onboarding@resend.dev — OTP only to your Resend signup email
# Production: verify domain at resend.com → use noreply@yourdomain.com
RESEND_FROM=onboarding@resend.dev

# OR Gmail SMTP (often blocked from cloud servers — if 535 error, use Resend instead)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=castmeproo@gmail.com
# SMTP_PASS=16_char_app_password_only
# SMTP_FROM=FBCast Pro <castmeproo@gmail.com>
# Free trial ending reminder (days before expiry)
TRIAL_REMINDER_DAYS_BEFORE=2
# Optional: override OAuth scopes (comma-separated)
# FB_OAUTH_SCOPES=public_profile,pages_show_list,pages_messaging,pages_read_engagement
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
# Match the default version in Meta App Dashboard → Settings → Advanced (e.g. v21.0)
FB_GRAPH_VERSION=v21.0

# Server
PORT=3000
BASE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
SESSION_SECRET=generate_a_random_32_char_string_here
APP_ENV=development

# Database (Railway: DATABASE_URL or MYSQL_*)
DATABASE_URL=mysql://user:password@localhost:3306/fbcast

# Stripe (SaaS billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_BASIC_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_GOLD_PRICE_ID=price_...
STRIPE_SAPPHIRE_PRICE_ID=price_...
STRIPE_PRO_UNLIMITED_PRICE_ID=price_...

# Admin
ADMIN_PASSWORD=change_me_in_production

# Optional
CONTACT_EMAIL=support@example.com
STRIPE_PUBLISHABLE_KEY_FRONTEND=

# Messenger tuning
MESSENGER_RETENTION_DAYS=7
MESSENGER_SYNC_COOLDOWN_MS=1800000

# AI Broadcast Assistant
# Groq (OpenAI-compatible): base URL must end with /v1 — uses /chat/completions
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.1-8b-instant
# openai | anthropic — auto-detected from URL if omitted (groq.com → openai)
AI_API_STYLE=openai
# Anthropic-style example:
# AI_BASE_URL=https://api.anthropic.com
# AI_API_STYLE=anthropic
# AI_MODEL=claude-3-5-haiku-20241022
# Per-user cap on YOUR server only (does not override provider free-tier limits).
AI_RATE_LIMIT_PER_MIN=20
