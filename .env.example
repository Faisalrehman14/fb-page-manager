# Facebook App
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Server
PORT=3000
BASE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
SESSION_SECRET=generate_a_random_32_char_string_here
APP_ENV=development

# Database (Railway: DATABASE_URL or MYSQL_*)
DATABASE_URL=mysql://user:password@localhost:3306/fbcast

# Stripe (SaaS billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_BASIC_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_GOLD_PRICE_ID=price_...
STRIPE_SAPPHIRE_PRICE_ID=price_...
STRIPE_PRO_UNLIMITED_PRICE_ID=price_...

# Admin
ADMIN_PASSWORD=change_me_in_production

# Optional
CONTACT_EMAIL=support@example.com
STRIPE_PUBLISHABLE_KEY_FRONTEND=

# Messenger tuning
MESSENGER_RETENTION_DAYS=7
MESSENGER_SYNC_COOLDOWN_MS=1800000

# AI Broadcast Assistant (Anthropic-compatible endpoint)
# Get the API key from your provider and DO NOT commit it.
AI_BASE_URL=https://opencode.ai/zen
AI_API_KEY=
AI_MODEL=minimax-m2.5-free
AI_RATE_LIMIT_PER_MIN=20
