# Facebook App Credentials
# Get these from https://developers.facebook.com/apps/
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here

# Server Configuration
PORT=3000
SESSION_SECRET=generate_a_random_32_char_string_here
BASE_URL=http://localhost:3000

# Security
CSRF_TOKEN_LENGTH=32

# Messenger / MySQL write tuning (reduces InnoDB redo log pressure)
MESSENGER_RETENTION_DAYS=7
MESSENGER_SYNC_COOLDOWN_MS=1800000
MESSENGER_SYNC_PARALLEL=3
MESSENGER_BULK_BATCH_SIZE=50
MESSENGER_CLEANUP_BATCH=500
MESSENGER_CLEANUP_DEFER_MS=10000
MESSENGER_POLL_MS=3000
MESSENGER_POLL_SOCKET_MS=8000
MESSENGER_POLL_MAX_CONVS=40
MESSENGER_CONV_INITIAL=30
MESSENGER_CONV_CACHE_MS=5000
MESSENGER_SYNC_MAX_FB_PAGES=3
MESSENGER_SYNC_MAX_CONVS=300
MESSENGER_SYNC_MSG_THREADS=25
MESSENGER_SEARCH_MIN_CHARS=2
MESSENGER_SEARCH_CONV_LIMIT=25
MESSENGER_SEARCH_MSG_LIMIT=30
