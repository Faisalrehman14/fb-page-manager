# Facebook App
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
# Match the default version in Meta App Dashboard → Settings → Advanced (e.g. v21.0)
FB_GRAPH_VERSION=v21.0

# Server
PORT=3000
BASE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
SESSION_SECRET=generate_a_random_32_char_string_here
APP_ENV=development

# Database (Railway: DATABASE_URL or MYSQL_*)
DATABASE_URL=mysql://user:password@localhost:3306/fbcast

# Stripe (SaaS billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_BASIC_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_GOLD_PRICE_ID=price_...
STRIPE_SAPPHIRE_PRICE_ID=price_...
STRIPE_PRO_UNLIMITED_PRICE_ID=price_...

# Binance Pay (crypto subscription checkout — Merchant Admin Portal API keys)
BINANCE_PAY_API_KEY=
BINANCE_PAY_API_SECRET=
# Charge in USD via fiatAmount (recommended) or set BINANCE_PAY_USE_FIAT=0 and BINANCE_PAY_CURRENCY=USDT
BINANCE_PAY_USE_FIAT=1
BINANCE_PAY_FIAT_CURRENCY=USD
BINANCE_PAY_CURRENCY=USDT
# Dev only: skip RSA webhook verify (never in production)
# BINANCE_PAY_WEBHOOK_SKIP_VERIFY=1

# Admin
ADMIN_PASSWORD=change_me_in_production

# Optional
CONTACT_EMAIL=support@example.com
STRIPE_PUBLISHABLE_KEY_FRONTEND=

# Messenger tuning
MESSENGER_RETENTION_DAYS=7
MESSENGER_SYNC_COOLDOWN_MS=1800000

# AI Broadcast Assistant
# Groq (OpenAI-compatible): base URL must end with /v1 — uses /chat/completions
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.1-8b-instant
# openai | anthropic — auto-detected from URL if omitted (groq.com → openai)
AI_API_STYLE=openai
# Anthropic-style example:
# AI_BASE_URL=https://api.anthropic.com
# AI_API_STYLE=anthropic
# AI_MODEL=claude-3-5-haiku-20241022
# Per-user cap on YOUR server only (does not override provider free-tier limits).
AI_RATE_LIMIT_PER_MIN=20
